default_platform(:ios)

platform :ios do
  lane :release do
    setup_ci

    # 1) ASC API key (твои переменные)
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64"),
      is_key_content_base64: true
    )

    # 2) В CI принудительно делаем Manual signing + правильный Team
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "L7YY6FT2M6",
      targets: ["Runner"]
    )

    # 3) Подтягиваем сертификаты/профили (readonly в CI)
    match(
      type: "appstore",
      readonly: true
    )

    # 4) Flutter + pods
    sh("cd .. && flutter pub get")
    sh("cd .. && flutter build ios --release --no-codesign")
    sh("bundle exec pod install --repo-update", chdir: "ios")

    # 5) Сборка IPA (archive + export) через gym
    gym(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      clean: true
    )

    # 6) Загрузка и (опционально) submit_for_review
    submit = (ENV["SUBMIT_FOR_REVIEW"].to_s.downcase == "true")

    upload_to_app_store(
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: submit
    )
  end
end